    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Verifica que la respuesta sea exitosa\r",
              "if (pm.response.code === 200) {\r",
              "    // Obtiene el token de la respuesta JSON\r",
              "    var jsonResponse = pm.response.json();\r",
              "    var token = jsonResponse.token; // Asegúrate de que 'token' sea el nombre de la propiedad en la respuesta\r",
              "\r",
              "    // Guarda el token en una variable de entorno llamada 'authToken'\r",
              "    pm.environment.set(\"token\", token);\r",
              "    \r",
              "    // Muestra un mensaje en los logs de Postman\r",
              "    console.log(\"Token guardado en la variable de entorno: \" + token);\r",
              "} else {\r",
              "    console.log(\"Error en la autenticación. Código de respuesta: \" + pm.response.code);\r",
              "}\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [],
